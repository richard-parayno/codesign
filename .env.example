# Optional server-side overrides. Codesign works without a .env file.
# By default the server resolves `codex` from its PATH.
# CODESIGN_CODEX_COMMAND=/absolute/path/to/codex

# Codesign's tested model and reasoning defaults.
# CODESIGN_CODEX_MODEL=gpt-5.6-luna
# CODESIGN_CODEX_EFFORT=high

# Generation timeout in milliseconds (1,000 through 600,000; default: 180,000).
# CODESIGN_AGENT_TIMEOUT_MS=180000
